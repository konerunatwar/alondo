# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use the publishable key from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy name also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# App URL — localhost locally, Railway domain in production (also set Supabase Site URL to this)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only (optional — for admin/server tasks, never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

RESEND_API_KEY=your-resend-api-key 